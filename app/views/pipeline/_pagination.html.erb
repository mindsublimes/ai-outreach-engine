<% start_idx = ((@current_page - 1) * @per_page) + 1 %>
<% end_idx = [@current_page * @per_page, @total_count].min %>
<nav class="pagination" aria-label="Pipeline pagination">
  <span class="pagination-info">Showing <%= start_idx %>–<%= end_idx %> of <%= @total_count %></span>
  <% if @total_pages > 1 %>
    <div class="pagination-controls">
      <% if @current_page > 1 %>
        <%= link_to "← Previous", pipeline_path(page: @current_page - 1), class: "pagination-btn" %>
      <% end %>
      <span class="pagination-pages">
        <% (1..@total_pages).each do |p| %>
          <% if p == @current_page %>
            <span class="pagination-page pagination-page--current"><%= p %></span>
          <% else %>
            <%= link_to p, pipeline_path(page: p), class: "pagination-page" %>
          <% end %>
        <% end %>
      </span>
      <% if @current_page < @total_pages %>
        <%= link_to "Next →", pipeline_path(page: @current_page + 1), class: "pagination-btn" %>
      <% end %>
    </div>
  <% end %>
</nav>
