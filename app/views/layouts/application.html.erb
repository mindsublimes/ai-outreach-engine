<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ai Outreach Engine" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <% if flash[:notice] || flash[:alert] %>
      <div id="flash-container" class="flash-wrapper">
        <% if flash[:notice] %><div class="flash flash--notice" data-dismiss="5"><%= flash[:notice] %></div><% end %>
        <% if flash[:alert] %><div class="flash flash--alert" data-dismiss="5"><%= flash[:alert] %></div><% end %>
      </div>
      <script>
        (function() {
          var els = document.querySelectorAll('#flash-container [data-dismiss]');
          var sec = parseInt(document.querySelector('[data-dismiss]')?.dataset.dismiss || '5', 10) * 1000;
          setTimeout(function() {
            els.forEach(function(el) {
              el.style.opacity = '0';
              el.style.transition = 'opacity 0.3s';
              setTimeout(function() { el.remove(); }, 300);
            });
            var container = document.getElementById('flash-container');
            if (container && !container.querySelector('.flash')) container.remove();
          }, sec);
        })();
      </script>
    <% end %>
    <%= yield %>
  </body>
</html>
